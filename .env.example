# ============================================================
# FileBrowser 环境变量配置模板
# 复制此文件为 .env 并按实际情况修改
# .env 已被 .gitignore 排除，请勿将真实路径提交到 git
# ============================================================

# ---- 文件存储目录（外接硬盘路径）-----------------------------
# 主存储路径（必填）：通常是外接硬盘挂载路径
# ExFAT/NTFS 硬盘需要先授权 OrbStack 全盘访问（见下方说明）
DISK1_PATH=/Volumes/JUN

# 第二块硬盘（可选，没有则留空或注释掉）
# DISK2_PATH=/Volumes/Backup

# 第三块硬盘（可选）
# DISK3_PATH=/Volumes/Archive

# ---- 用户权限（必须与 macOS 当前用户一致）--------------------
# 通过 `id -u` 和 `id -g` 获取
PUID=502
PGID=20

# ---- 服务端口 -----------------------------------------------
# filebrowser 在宿主机上监听的端口
PORT=8080

# ---- 管理员账号（初始化后可在 Web 界面修改）------------------
ADMIN_USERNAME=admin
# 密码长度至少 12 位，建议包含大小写字母、数字、符号
ADMIN_PASSWORD=ChangeMe123!@#

# ---- 时区 ---------------------------------------------------
TZ=Asia/Shanghai
